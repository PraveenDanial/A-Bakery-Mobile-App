<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="left"
    android:background="@drawable/createpagepra"
    tools:context=".Activities.ProductActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="300dp"
        android:layout_marginLeft="50dp"
        android:padding="80dp">

        <EditText
            android:id="@+id/txt_P_ProductID"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ems="10"
            android:hint="Enter Product ID"
            android:textColor="@color/black"
            android:textColorHint="@color/black"
            android:inputType="textPersonName" />

        <EditText
            android:id="@+id/txt_P_ProductName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ems="10"
            android:hint="Enter Product Name"
            android:textColor="@color/black"
            android:textColorHint="@color/black"
            android:inputType="textPersonName" />

        <Spinner
            android:id="@+id/sp_P_Category"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <EditText
            android:id="@+id/txt_P_Price"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ems="10"
            android:hint="Enter Price"
            android:inputType="textPersonName"
            android:textColor="@color/black"
            android:textColorHint="@color/black"/>

        <EditText
            android:id="@+id/txt_P_Quantity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ems="10"
            android:hint="Enter Quantity"
            android:textColorHint="@color/black"
            android:textColor="@color/black"
            android:inputType="textPersonName" />

        <Button
            android:id="@+id/btn_P_SubmitProduct"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="SUBMIT PRODUCT"
            android:backgroundTint="@color/white"
            android:textColor="@color/black"
            android:textSize="18sp"
            app:cornerRadius="20dp"/>

    </LinearLayout>

</LinearLayout>